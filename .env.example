# ─── Bac DZ AI — Environment Variables ───────────────────────────────────────

# Socket.io Server URL
# Development: leave empty (auto-connects to http://localhost:3001)
# Production:  set to your Vercel URL (auto-detected) or external server
VITE_SOCKET_URL=

# Firebase Config (already hardcoded in src/lib/firebase.ts)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_DATABASE_URL=

# Gemini API Key (set via Admin Panel in the app)
# VITE_GEMINI_API_KEY=

# YouTube API Key (set via Admin Panel in the app)
# VITE_YOUTUBE_API_KEY=
